/*
  ── Vercel _headers ────────────────────────────────
  Untuk override default Vercel CORS (wildcard)
  File ini lebih high-priority daripada vercel.json headers
  ────────────────────────────────────────────────────
*/
/assets/*
  Access-Control-Allow-Origin: https://sop-portal-nine.vercel.app

/api/*
  Access-Control-Allow-Origin: https://sop-portal-nine.vercel.app
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
